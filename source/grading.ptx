<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="Grading">

  <title>Grading</title>
  
   <subsection>
      <title>Homework: Problems Sets</title>

      <p>
        We will have a number of problem sets throughout the semester
      </p>
    

    </subsection>

    <subsection>
    <title>Presentations</title>

      <p>
        Each student will be responsible for one or more presentations throughout the semester.  Details to follow.  
      </p>
    </subsection>


   <subsection>
    <title>Exams</title>
        <p>
          We will have two in-semester exams.  Each exam will be announced at least a week in advance.
        </p>
  </subsection>

  <subsection>
    <title>Final Exam</title>

      <p>
        Our cumulative final exam will be held Thursday, May 14th from 11:30am-2:30pm in Hemenway Hall 405.
      </p>
    </subsection>




    <subsection>
      <title>Final Grades</title>

      <p>
        The following percentage weights are used for calculating your weighted course average.
      </p>
    
      <tabular halign="right">
        <row header="yes" bottom="minor" >
          <cell>Category</cell>
          <cell>Weight</cell>
        </row>
        <row>
          <cell>Problem Sets</cell>
          <cell>40%</cell>
        </row>
        <row>
          <cell>Presentations</cell>
          <cell>10%</cell>
        </row>
        <row>
          <cell>Exams</cell>
          <cell>25%</cell>
        </row>
        <row>
          <cell>Final Exam</cell>
          <cell>25%</cell>
        </row>
      </tabular>


      <p>
        Final grades will be assigned based on the following scale.
      </p>

      <tabular halign="center">
        <row header="yes" bottom="minor" >
          <cell>Percentage</cell>
          <cell>Grade</cell>
        </row>
        <row>
          <cell>93-100</cell>
          <cell>A</cell>
        </row>
        <row>
          <cell>90-93</cell>
          <cell>A-</cell>
        </row>
        <row>
          <cell>87-90</cell>
          <cell>B+</cell>
        </row>
        <row>
          <cell>83-87</cell>
          <cell>B</cell>
        </row>
        <row>
          <cell>80-83</cell>
          <cell>B-</cell>
        </row>
        <row>
          <cell>77-80</cell>
          <cell>C+</cell>
        </row>
        <row>
          <cell>73-77</cell>
          <cell>C</cell>
        </row>
        <row>
          <cell>70-73</cell>
          <cell>C-</cell>
        </row>
        <row>
          <cell>67-70</cell>
          <cell>D+</cell>
        </row>
        <row>
          <cell>63-67</cell>
          <cell>D</cell>
        </row>
        <row>
          <cell>60-63</cell>
          <cell>D-</cell>
        </row>
        <row>
          <cell>Below 60</cell>
          <cell>F</cell>
        </row>
      </tabular>

    </subsection>


  </section>
